ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_cloned_voice_id_here
# Optional: paths to libass-enabled ffmpeg/ffprobe (default to PATH). Needed for captions if your default ffmpeg lacks libass.
# FFMPEG=/usr/local/opt/ffmpeg-full/bin/ffmpeg
# FFPROBE=/usr/local/opt/ffmpeg-full/bin/ffprobe
YOUTUBE_CLIENT_ID=your_saved_client_id
YOUTUBE_CLIENT_SECRET=your_saved_client_secret
